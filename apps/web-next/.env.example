# Postgres from repo-root docker-compose.dev.yml (host port default 5435;
# override with SPRINKLER_DB_PORT when starting compose and mirror it here).
DATABASE_URL=postgres://sprinkler:sprinkler@localhost:5435/sprinkler

# Better Auth — generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=CHANGE_ME
BETTER_AUTH_URL=http://localhost:3000

# Comma-separated origins allowed to call the auth endpoints. Requests from
# any other Origin get 403 INVALID_ORIGIN. Defaults to
# http://localhost:3000,http://127.0.0.1:3000 when unset. In production this
# must list the real scheme://host[:port] users hit (the ingress hostname).
TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Executor REST API (docs/API.md). Server-side only — never sent to browsers.
# Real controller lives at http://127.0.0.1:8000; for developing write flows
# use the stub: npm run stub-executor  (listens on 8899).
EXECUTOR_URL=http://127.0.0.1:8899

# Used only by `npm run seed` to create the initial admin.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_MIN_8_CHARS
